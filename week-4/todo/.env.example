# ========================================
# .env 파일 형식 문서 (이 파일은 커밋해도 안전합니다 — 실제 값은 .env 에)
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요.
#   cp .env.example .env
# DB_PASSWORD 는 raw 값 그대로 입력하세요 (URL 인코딩/따옴표 불필요).
# ========================================
DB_HOST=your-project.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.yourprojectref
DB_PASSWORD=your-database-password
DB_NAME=postgres
PORT=3001
