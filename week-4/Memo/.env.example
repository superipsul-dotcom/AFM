# ========================================
# .env 파일 형식 문서 (이 파일은 커밋해도 안전합니다 — 실제 값은 .env 에)
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요.
#   cp .env.example .env
# ========================================
# Supabase Postgres 연결 문자열.
#   형식: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#   - HOST  : aws-1-<region>.pooler.supabase.com
#   - PORT  : 6543 (트랜잭션 풀러/pgBouncer). prepared statement 이슈 시 5432 로.
#   - USER  : postgres.<projectref>
#   - PASS  : 대시보드의 DB 비밀번호 (URL 인코딩/따옴표 불필요)
DATABASE_URL=postgresql://postgres.yourprojectref:your-password@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# 서버 포트 (선택, 기본 3002)
PORT=3002
