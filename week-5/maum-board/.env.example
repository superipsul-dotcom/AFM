# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워 넣으세요.
#   cp .env.example .env

# Supabase 대시보드 → Project Settings → Database → Connection string (Transaction pooler, :6543)
DATABASE_URL=postgresql://postgres.<프로젝트ref>:<비밀번호>@<리전>.pooler.supabase.com:6543/postgres

# 서버 포트
PORT=3012

# JWT 서명 비밀키 — 아래 명령으로 생성한 랜덤 값을 붙여넣으세요.
#   openssl rand -hex 32
JWT_SECRET=
