# ===== 멀티유저 할 일 관리앱 환경 변수 (.env.example) =====
# 실제 값은 .env 에 넣으세요. 이 파일에는 절대 진짜 비밀을 적지 마세요(.env 만 .gitignore 됨).

# Supabase PostgreSQL 연결 문자열 (트랜잭션 풀러 :6543, pgBouncer)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# 서버 포트 (로컬 기본 3006)
PORT=3006

# JWT(HS256) 서명 비밀. 길고 무작위한 문자열로 교체하세요.
# 예) node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=랜덤-시크릿-넣기
