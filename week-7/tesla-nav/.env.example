# developer.tesla.com → 앱 생성 후 발급되는 값
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=

# 테슬라에 등록한 도메인. 공개키 호스팅 위치이자 redirect_uri의 출처가 된다.
# 테슬라 앱 설정의 allowed_origins와 정확히 일치해야 한다.
PUBLIC_ORIGIN=https://afm-tesla-nav.vercel.app

# 한국(KR)은 테슬라 기준 Asia-Pacific이고, APAC은 NA 엔드포인트를 쓴다.
# 지역이 틀리면 API가 412로 거절한다. 한국이면 이 값을 그대로 두면 된다.
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# /auth/callback 화면에 뜨는 값을 붙여넣는다. ②단계에서 실차를 때릴 때 쓴다.
TESLA_REFRESH_TOKEN=
